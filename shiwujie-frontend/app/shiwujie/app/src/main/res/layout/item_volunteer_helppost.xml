<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="@color/white"
    android:foreground="?android:attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 求助帖头部区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <!-- 求助图标 -->
            <LinearLayout
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/help_icon_background"
                android:gravity="center"
                android:layout_marginEnd="12dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_help"
                    android:tint="@color/white" />
            </LinearLayout>

            <!-- 求助信息 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/helppostIdText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="求助帖 #12345"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="需要您的帮助"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

            <!-- 状态标签 -->
            <TextView
                android:id="@+id/postStatusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="待响应"
                android:textSize="11sp"
                android:textColor="@color/white"
                android:background="@drawable/status_urgent_background"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 求助内容区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/help_content_background"
            android:padding="12dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="求助内容"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/helpContentText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="请详细描述您需要帮助的内容..."
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:lineSpacingExtra="3dp" />
        </LinearLayout>

        <!-- 求助地点区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_location"
                android:tint="@color/primary_blue"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="求助地点："
                android:textSize="13sp"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/helpLocationText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="请输入您的具体位置"
                android:textSize="13sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 底部信息区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- 左侧信息 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/postTimeText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="发布时间: 2024-01-01 12:00"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:drawableStart="@drawable/ic_time"
                    android:drawablePadding="4dp"
                    android:gravity="center_vertical" />

                <TextView
                    android:id="@+id/communityNameText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="社区: 测试社区"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="4dp"
                    android:drawableStart="@drawable/ic_community"
                    android:drawablePadding="4dp"
                    android:gravity="center_vertical" />
            </LinearLayout>

            <!-- 响应按钮 -->
            <Button
                android:id="@+id/respondHelppostButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="立即响应"
                android:textSize="13sp"
                android:textColor="@color/white"
                android:background="@drawable/respond_button_background"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:minWidth="0dp"
                android:elevation="4dp" />

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView> 