<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- 远程视频容器 -->
    <FrameLayout
        android:id="@+id/remote_video_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_centerInParent="true" />

    <!-- 本地视频容器 (小窗口) -->
    <FrameLayout
        android:id="@+id/local_video_container"
        android:layout_width="120dp"
        android:layout_height="160dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="60dp"
        android:layout_marginEnd="20dp"
        android:background="@android:color/transparent" />

    <!-- 顶部状态栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@android:color/transparent">

        <!-- 通话状态 -->
        <TextView
            android:id="@+id/tv_call_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="通话中"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- 盲人信息 -->
        <TextView
            android:id="@+id/tv_blind_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="4dp"
            android:text="视障用户: 未知"
            android:textColor="@android:color/white"
            android:textSize="14sp" />

        <!-- 通话时长 -->
        <TextView
            android:id="@+id/tv_call_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:text="00:00"
            android:textColor="@android:color/white"
            android:textSize="16sp" />

    </LinearLayout>

    <!-- 底部控制栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:padding="30dp"
        android:background="@android:color/transparent">

        <!-- 控制按钮行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="30dp">

            <!-- 麦克风按钮 -->
            <ImageButton
                android:id="@+id/btn_mute"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginEnd="20dp"
                android:background="@drawable/bg_control_button"
                android:src="@drawable/icon_mic_on"
                android:scaleType="centerInside"
                android:contentDescription="麦克风" />

            <!-- 摄像头翻转按钮 -->
            <ImageButton
                android:id="@+id/btn_switch_camera"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginEnd="20dp"
                android:background="@drawable/bg_control_button"
                android:src="@drawable/icon_camera_switch"
                android:scaleType="centerInside"
                android:contentDescription="切换摄像头" />

            <!-- 扬声器按钮 -->
            <ImageButton
                android:id="@+id/btn_speaker"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="@drawable/bg_control_button"
                android:src="@drawable/icon_speaker_on"
                android:scaleType="centerInside"
                android:contentDescription="扬声器" />

        </LinearLayout>

        <!-- 挂断按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center">

            <ImageButton
                android:id="@+id/btn_hangup"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/bg_hangup_button"
                android:src="@drawable/icon_hangup"
                android:scaleType="centerInside"
                android:contentDescription="挂断" />

        </LinearLayout>

    </LinearLayout>

</RelativeLayout> 