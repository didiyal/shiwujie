<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="@color/background_light">

    <!-- 顶部状态栏占位区域，占页面高度的3% -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.03"
        android:background="@color/background_light" />

    <!-- 内容区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.97"
        android:orientation="vertical"
        android:background="@color/background_light">

        <!-- 顶部标题 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="我的社区"
            android:textSize="24sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:gravity="center"
            android:padding="20dp"
            android:background="@color/white" />

        <!-- 导航标签 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/white"
            android:paddingHorizontal="16dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/tabMyCommunity"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="我的社区"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:gravity="center"
                android:padding="12dp"
                android:background="?android:attr/selectableItemBackground" />

            <TextView
                android:id="@+id/tabCommunityActivity"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="社区活动"
                android:textSize="16sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:padding="12dp"
                android:background="?android:attr/selectableItemBackground" />

            <TextView
                android:id="@+id/tabCommunityHelp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="社区求助"
                android:textSize="16sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:padding="12dp"
                android:background="?android:attr/selectableItemBackground" />

        </LinearLayout>

        <!-- 选中指示器 -->
        <View
            android:id="@+id/tabIndicator"
            android:layout_width="60dp"
            android:layout_height="3dp"
            android:background="@color/primary_blue"
            android:layout_marginStart="16dp" />

        <!-- 内容区域 -->
        <FrameLayout
            android:id="@+id/contentContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- 社区活动页面 -->
            <LinearLayout
                android:id="@+id/communityActivityLayout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="visible">

                <!-- 搜索栏 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@color/white">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="发现精彩活动"
                        android:textSize="20sp"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <EditText
                            android:id="@+id/activitySearchEditText"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:background="@drawable/edit_text_background"
                            android:hint="搜索活动名称、地点或内容"
                            android:paddingHorizontal="16dp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_hint"
                            android:textSize="14sp"
                            android:inputType="text"
                            android:imeOptions="actionSearch" />

                        <Button
                            android:id="@+id/activitySearchButton"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:layout_marginStart="12dp"
                            android:background="@drawable/button_primary"
                            android:text="搜索"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:minWidth="60dp"
                            android:paddingHorizontal="16dp"/>

                    </LinearLayout>

                </LinearLayout>

                <!-- 活动列表 -->
                <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
                    android:id="@+id/activitySwipeRefreshLayout"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/activityRecyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="8dp" />

                </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

            </LinearLayout>

            <!-- 社区求助页面 -->
            <LinearLayout
                android:id="@+id/communityHelpLayout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- 搜索栏 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:background="@color/white">

                    <EditText
                        android:id="@+id/helpSearchEditText"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:background="@drawable/edit_text_background"
                        android:hint="搜索求助信息"
                        android:paddingHorizontal="16dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:textSize="14sp" />

                    <Button
                        android:id="@+id/helpSearchButton"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/button_primary"
                        android:text="搜索"
                        android:textColor="@color/white"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- 操作栏 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:background="@color/white"
                    android:gravity="center_vertical">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_edit"
                        android:layout_marginEnd="4dp" />

                    <Button
                        android:id="@+id/addHelpPostButton"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/button_primary"
                        android:text="+"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- 求助列表 -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/helpRecyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="8dp" />

            </LinearLayout>

            <!-- 我的社区页面 -->
            <LinearLayout
                android:id="@+id/myCommunityLayout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- 未加入社区状态 -->
                <LinearLayout
                    android:id="@+id/noJoinLayout"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:visibility="visible">



                    <LinearLayout
                        android:id="@+id/communitySelectionLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/card_background"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="加入社区"
                            android:textSize="16sp"
                            android:textColor="@color/text_primary"
                            android:layout_marginBottom="16dp" />

                        <EditText
                            android:id="@+id/searchCommunityEditText"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/edit_text_background"
                            android:hint="输入社区ID"
                            android:inputType="number"
                            android:paddingHorizontal="16dp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_hint"
                            android:textSize="14sp" />

                        <Button
                            android:id="@+id/searchCommunityButton"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/button_primary"
                            android:text="搜索社区"
                            android:textColor="@color/white"
                            android:textSize="16sp" />

                        <LinearLayout
                            android:id="@+id/communityInfoLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginTop="16dp"
                            android:visibility="gone">

                            <TextView
                                android:id="@+id/communityNameText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="16sp"
                                android:textColor="@color/text_primary"
                                android:layout_marginBottom="8dp" />

                            <TextView
                                android:id="@+id/communityDescriptionText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="14sp"
                                android:textColor="@color/text_secondary"
                                android:layout_marginBottom="16dp" />

                            <Button
                                android:id="@+id/confirmJoinButton"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:background="@drawable/button_primary"
                                android:text="确认加入"
                                android:textColor="@color/white"
                                android:textSize="16sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- 已加入社区状态 -->
                <LinearLayout
                    android:id="@+id/joinedLayout"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:gravity="center"
                    android:padding="20dp">

                    <!-- 快捷操作按钮 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:background="@color/white"
                        android:layout_marginBottom="20dp">

                        <!-- 第一行按钮 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">

                            <Button
                                android:id="@+id/helpPostButton"
                                android:layout_width="0dp"
                                android:layout_height="60dp"
                                android:layout_weight="1"
                                android:layout_marginEnd="10dp"
                                android:background="@drawable/button_primary"
                                android:text="我的求助"
                                android:textColor="@color/white"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <Button
                                android:id="@+id/activityButton"
                                android:layout_width="0dp"
                                android:layout_height="60dp"
                                android:layout_weight="1"
                                android:layout_marginStart="10dp"
                                android:background="@drawable/button_secondary"
                                android:text="社区活动"
                                android:textColor="@color/text_primary"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- 第二行按钮 -->
                        <Button
                            android:id="@+id/myActivitiesButton"
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:background="@drawable/button_secondary"
                            android:text="参与的活动"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- 社区信息卡片 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:background="@color/white">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="我的社区信息"
                            android:textSize="18sp"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"
                            android:layout_marginBottom="16dp" />

                        <!-- 社区名称 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="社区名称："
                                android:textSize="14sp"
                                android:textColor="@color/text_secondary" />

                            <TextView
                                android:id="@+id/communityTitleText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="社区名称"
                                android:textSize="14sp"
                                android:textColor="@color/text_primary"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- 社区描述 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="社区描述："
                                android:textSize="14sp"
                                android:textColor="@color/text_secondary" />

                            <TextView
                                android:id="@+id/communityDescText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="社区描述"
                                android:textSize="14sp"
                                android:textColor="@color/text_primary" />
                        </LinearLayout>

                        <!-- 社区ID -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="社区ID："
                                android:textSize="14sp"
                                android:textColor="@color/text_secondary" />

                            <TextView
                                android:id="@+id/communityIdText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="123456"
                                android:textSize="14sp"
                                android:textColor="@color/text_primary"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- 加入时间 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="加入时间："
                                android:textSize="14sp"
                                android:textColor="@color/text_secondary" />

                            <TextView
                                android:id="@+id/joinTimeText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="2024-01-01"
                                android:textSize="14sp"
                                android:textColor="@color/text_primary" />
                        </LinearLayout>

                        <!-- 社区状态 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="社区状态："
                                android:textSize="14sp"
                                android:textColor="@color/text_secondary" />

                            <TextView
                                android:id="@+id/communityStatusText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="已加入"
                                android:textSize="14sp"
                                android:textColor="@color/success_green"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
            </FrameLayout>
        </LinearLayout>
    </LinearLayout>