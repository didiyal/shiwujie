<?xml version="1.0" encoding="utf-8"?>
<!-- 障碍物检测布局文件 - 真正功能实现版本 -->
<!-- 改造说明：严格按照backend_service.py的UI逻辑实现，包括摄像头预览、结果图像显示等 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@android:color/white">

    <!-- 标题区域 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="障碍物检测系统"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="16dp"
        android:textColor="@android:color/black" />

    <!-- 摄像头预览区域 - 对应原Python代码的frame输入显示 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="摄像头预览 (实时输入)"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@android:color/darker_gray"
        android:layout_marginBottom="8dp" />

    <androidx.camera.view.PreviewView
        android:id="@+id/camera_preview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/gray"
        android:layout_marginBottom="16dp" />

    <!-- 检测结果区域 - 对应原Python代码的detections和unknown_obstacle输出显示 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="检测结果"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@android:color/darker_gray"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/detection_result"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="16dp"
        android:textSize="14sp"
        android:textColor="@android:color/black"
        android:background="@android:color/white"
        android:padding="16dp"
        android:minHeight="150dp"
        android:gravity="top|start"
        android:text="等待检测结果..."
        android:scrollbars="vertical" />

    <!-- 结果图像显示区域 - 对应原Python代码的annotated_frame输出显示 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="处理后的图像"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@android:color/darker_gray"
        android:layout_marginBottom="8dp" />

    <ImageView
        android:id="@+id/result_image"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scaleType="centerCrop"
        android:background="@color/gray"
        android:visibility="gone"
        android:layout_marginBottom="16dp" />

    <!-- 处理时间显示区域 - 对应原Python代码的耗时统计显示 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="处理性能"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@android:color/darker_gray"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/processing_time"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:textSize="14sp"
        android:textColor="@android:color/darker_gray"
        android:gravity="center"
        android:text="处理耗时: -- ms" />

    <!-- 控制按钮区域 - 对应原Python代码的start/stop逻辑 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- 开始检测按钮 - 对应原Python代码的startDetection逻辑 -->
        <Button
            android:id="@+id/btn_start_detection"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="开始检测"
            android:textSize="16sp"
            android:backgroundTint="@android:color/holo_green_dark"
            android:textColor="@android:color/white" />

        <!-- 停止检测按钮 - 对应原Python代码的stopDetection逻辑 -->
        <Button
            android:id="@+id/btn_stop_detection"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="停止检测"
            android:textSize="16sp"
            android:backgroundTint="@android:color/holo_red_dark"
            android:textColor="@android:color/white"
            android:enabled="false" />

    </LinearLayout>

    <!-- 状态信息区域 - 对应原Python代码的状态显示 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="版本: 功能实现版 v2.0"
        android:textSize="12sp"
        android:textColor="@android:color/darker_gray"
        android:gravity="center" />

</LinearLayout>
