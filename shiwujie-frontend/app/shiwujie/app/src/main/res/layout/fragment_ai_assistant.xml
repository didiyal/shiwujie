<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/ai_assistant_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white">

    <!--<TextView
        android:id="@+id/tv_debug_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="AI页面测试"
        android:textSize="24sp"
        android:textColor="@color/primary_blue"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="8dp"
        android:visibility="gone" />-->


    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/top_app_bar"
        style="@style/Widget.Material3.Toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:backgroundTint="?attr/colorSurface"
        app:title="AI 助理"
        app:titleCentered="true"
        app:titleTextColor="@color/primary_blue"
        android:elevation="0dp"
        tools:ignore="PrivateResource" />


    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:layout_weight="1"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <LinearLayout
            android:id="@+id/chat_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">


            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_greeting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardUseCompatPadding="true"
                app:cardCornerRadius="18dp"
                app:cardElevation="8dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">


                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_greeting_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="您好，我是你的智能AI助理。"
                            android:textColor="#111111"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:letterSpacing="0.01"
                            android:lineHeight="22sp" />

                        <TextView
                            android:id="@+id/tv_greeting_desc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textColor="#667185"
                            android:textSize="14sp"
                            android:lineSpacingExtra="2sp"
                            android:letterSpacing="0.005"
                            android:text="很高兴能和你互动" />
                    </LinearLayout>


                    <ImageView
                        android:id="@+id/img_robot"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_marginStart="12dp"
                        android:padding="10dp"
                        android:contentDescription="吉祥物"
                        android:background="@android:color/transparent"
                        app:tint="@color/blue_600"
                        android:scaleType="centerInside"
                        tools:src="@drawable/community" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>


            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_suggestions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardUseCompatPadding="true"
                app:cardCornerRadius="18dp"
                app:cardElevation="8dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/tv_suggest_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="您可以尝试这样问我："
                        android:textColor="#111111"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:letterSpacing="0.01"
                        android:layout_marginBottom="6dp" />


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@android:color/white"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp">


                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:gravity="center_vertical"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            android:background="@android:color/transparent"
                            android:layout_marginTop="2dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:textColor="#1F2937"
                                android:textSize="15sp"
                                android:maxLines="1"
                                android:ellipsize="end"
                                android:letterSpacing="0.005"
                                android:text="为我介绍一下软件" />

                          <!--  <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:contentDescription="更多"
                                app:tint="#C2CAD6"
                                tools:src="@drawable/ic_chevron_right_24" />-->
                        </LinearLayout>


                        <com.google.android.material.divider.MaterialDivider
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:visibility="gone" />


                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:gravity="center_vertical"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            android:background="@android:color/transparent"
                            android:layout_marginTop="2dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:textColor="#1F2937"
                                android:textSize="15sp"
                                android:maxLines="1"
                                android:ellipsize="end"
                                android:letterSpacing="0.005"
                                android:text="如何使用AI功能" />

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:contentDescription="更多"
                                app:tint="#C2CAD6"
                                tools:src="@drawable/ic_chevron_right_24" />
                        </LinearLayout>

                        <com.google.android.material.divider.MaterialDivider
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:visibility="gone" />


                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:gravity="center_vertical"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            android:background="@android:color/transparent"
                            android:layout_marginTop="2dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:textColor="#1F2937"
                                android:textSize="15sp"
                                android:maxLines="1"
                                android:ellipsize="end"
                                android:letterSpacing="0.005"
                                android:text="介绍一下软件的功能，提供一份使用指南" />

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:contentDescription="更多"
                                app:tint="#C2CAD6"
                                tools:src="@drawable/ic_chevron_right_24" />
                        </LinearLayout>

                        <com.google.android.material.divider.MaterialDivider
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:visibility="gone" />


                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:gravity="center_vertical"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            android:background="@android:color/transparent"
                            android:layout_marginTop="2dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:textColor="#1F2937"
                                android:textSize="15sp"
                                android:maxLines="1"
                                android:ellipsize="end"
                                android:letterSpacing="0.005"
                                android:text="AI能够做什么" />

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:contentDescription="更多"
                                app:tint="#C2CAD6"
                                tools:src="@drawable/ic_chevron_right_24" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>


            <Space
                android:layout_width="match_parent"
                android:layout_height="8dp" />


            <com.google.android.material.card.MaterialCardView
                android:id="@+id/bubble_assistant_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="56dp"
                app:cardCornerRadius="18dp"
                app:strokeColor="@color/blue_100"
                app:strokeWidth="1dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@android:color/white"
                android:layout_gravity="start">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="280dp"
                    android:padding="12dp"
                    android:textSize="15sp"
                    android:textColor="#222222"
                    android:text="你好！我可以帮你总结、生成内容或完成任务。需要我做什么？" />
            </com.google.android.material.card.MaterialCardView>


            <com.google.android.material.card.MaterialCardView
                android:id="@+id/bubble_user_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginStart="56dp"
                app:cardCornerRadius="18dp"
                app:strokeWidth="0dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/primary_blue"
                android:layout_gravity="end">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="280dp"
                    android:padding="12dp"
                    android:textSize="15sp"
                    android:textColor="@color/white"
                    android:text="帮我规划一下从家到公司的最快通勤路线。" />
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>


    <com.google.android.material.card.MaterialCardView
        android:id="@+id/action_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:strokeWidth="0dp"
        app:cardBackgroundColor="@android:color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">


            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_back"
                style="@style/Widget.Material3.Button.Icon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                app:cornerRadius="14dp"
                app:iconTint="@color/blue_700"
                app:backgroundTint="@color/blue_50"
                app:rippleColor="@color/blue_100"
                android:contentDescription="返回"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="22dp"
                app:icon="@drawable/ic_back"
                tools:ignore="PrivateResource" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_camera"
                style="@style/Widget.Material3.Button.Icon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                app:cornerRadius="14dp"
                app:iconTint="@color/blue_700"
                app:backgroundTint="@color/blue_50"
                app:rippleColor="@color/blue_100"
                android:contentDescription="拍照"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="22dp"
                app:icon="@drawable/icon_camera_switch"
                tools:ignore="PrivateResource" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_voice"
                style="@style/Widget.Material3.Button.Icon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                app:cornerRadius="14dp"
                app:iconTint="@color/blue_700"
                app:backgroundTint="@color/blue_50"
                app:rippleColor="@color/blue_100"
                android:contentDescription="语音输入"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="22dp"
                app:icon="@drawable/ic_mic_24"
                tools:ignore="PrivateResource" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_ai_assist"
                style="@style/Widget.Material3.Button.Icon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                app:cornerRadius="14dp"
                app:iconTint="@color/blue_700"
                app:backgroundTint="@color/blue_50"
                app:rippleColor="@color/blue_100"
                android:contentDescription="AI 协助"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="22dp"
                app:icon="@drawable/ai"
                tools:ignore="PrivateResource" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>


    <LinearLayout
        android:id="@+id/message_bar_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@android:color/white"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp">

      <!--  <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:boxBackgroundMode="filled"
            app:boxBackgroundColor="#FFFFFFFF"
            app:boxStrokeColor="@color/blue_600"
            app:boxStrokeWidth="2dp"
            app:boxCornerRadiusTopStart="28dp"
            app:boxCornerRadiusTopEnd="28dp"
            app:boxCornerRadiusBottomStart="28dp"
            app:boxCornerRadiusBottomEnd="28dp"
            app:startIconDrawable="@drawable/ic_mic_24"
            app:startIconTint="@color/blue_600"
            app:endIconMode="none">-->

         <!--   <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_message"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@android:color/transparent"
                android:hint="提供一份电商平台的用户画像"
                android:paddingEnd="8dp"
                android:textColor="#1F2937"
                android:textColorHint="#9AA4B2"
                android:letterSpacing="0.005"
                android:imeOptions="actionSend"
                android:inputType="textCapSentences|textMultiLine"
                android:maxLines="3"
                android:minLines="1" />
        </com.google.android.material.textfield.TextInputLayout>-->
    </LinearLayout>

</LinearLayout>