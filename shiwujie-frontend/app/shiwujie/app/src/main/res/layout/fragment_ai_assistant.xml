<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/ai_assistant_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white">




    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/top_app_bar"
        style="@style/Widget.Material3.Toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:backgroundTint="?attr/colorSurface"
        app:title="AI 助理"
        app:titleCentered="true"
        app:titleTextColor="@color/primary_blue"
        android:elevation="0dp"
        tools:ignore="PrivateResource" />

    <!-- 录音状态提示 -->
    <TextView
        android:id="@+id/tv_recording_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:text=""
        android:textColor="@color/primary_blue"
        android:textSize="14sp"
        android:textStyle="bold"
        android:background="@drawable/bg_recording_status"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:visibility="gone"
        tools:visibility="visible"
        tools:text="正在录音..." />


    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:layout_weight="1"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <LinearLayout
            android:id="@+id/chat_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">



-->

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_suggestions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardUseCompatPadding="true"
                app:cardCornerRadius="18dp"
                app:cardElevation="8dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/blue_100">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/tv_suggest_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="您可以尝试这样问我："
                        android:textColor="#111111"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:letterSpacing="0.01"
                        android:layout_marginBottom="6dp" />


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@color/blue_100"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp">


                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:gravity="center_vertical"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            android:background="@color/blue_100"
                            android:layout_marginTop="2dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:textColor="#1F2937"
                                android:textSize="15sp"
                                android:maxLines="1"
                                android:ellipsize="end"
                                android:letterSpacing="0.005"
                                android:text="为我介绍一下软件" />

                          <!--  <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:contentDescription="更多"
                                app:tint="#C2CAD6"
                                tools:src="@drawable/ic_chevron_right_24" />-->
                        </LinearLayout>


                        <com.google.android.material.divider.MaterialDivider
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:visibility="gone" />


                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:gravity="center_vertical"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            android:background="@color/blue_100"
                            android:layout_marginTop="2dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:textColor="#1F2937"
                                android:textSize="15sp"
                                android:maxLines="1"
                                android:ellipsize="end"
                                android:letterSpacing="0.005"
                                android:text="如何使用AI功能" />

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:contentDescription="更多"
                                app:tint="#C2CAD6"
                                tools:src="@drawable/ic_chevron_right_24" />
                        </LinearLayout>

                        <com.google.android.material.divider.MaterialDivider
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:visibility="gone" />


                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:gravity="center_vertical"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            android:background="@color/blue_100"
                            android:layout_marginTop="2dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:textColor="#1F2937"
                                android:textSize="15sp"
                                android:maxLines="1"
                                android:ellipsize="end"
                                android:letterSpacing="0.005"
                                android:text="介绍一下软件的功能，提供一份使用指南" />

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:contentDescription="更多"
                                app:tint="#C2CAD6"
                                tools:src="@drawable/ic_chevron_right_24" />
                        </LinearLayout>

                        <com.google.android.material.divider.MaterialDivider
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:visibility="gone" />


                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:gravity="center_vertical"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            android:background="@color/blue_100"
                            android:layout_marginTop="2dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:textColor="#1F2937"
                                android:textSize="15sp"
                                android:maxLines="1"
                                android:ellipsize="end"
                                android:letterSpacing="0.005"
                                android:text="AI能够做什么" />

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:contentDescription="更多"
                                app:tint="#C2CAD6"
                                tools:src="@drawable/ic_chevron_right_24" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>


            <Space
                android:layout_width="match_parent"
                android:layout_height="8dp" />




            <com.google.android.material.card.MaterialCardView
                android:id="@+id/bubble_user_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginStart="56dp"
                app:cardCornerRadius="18dp"
                app:strokeWidth="0dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/primary_blue"
                android:layout_gravity="end">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="280dp"
                    android:padding="12dp"
                    android:textSize="15sp"
                    android:textColor="@color/white"
                    android:text="介绍一下AI功能的使用。" />
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>


    <!-- 悬浮的历史记录按钮 -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_history"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|bottom"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="100dp"
        android:src="@drawable/ic_time"
        app:backgroundTint="@color/primary_blue"
        app:tint="@color/white"
        app:fabSize="normal"
        android:contentDescription="历史记录" />



    <com.google.android.material.card.MaterialCardView
        android:id="@+id/action_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:strokeWidth="0dp"
        app:cardBackgroundColor="@android:color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">


            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_back"
                style="@style/Widget.Material3.Button.Icon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                app:cornerRadius="14dp"
                app:iconTint="@color/blue_700"
                app:backgroundTint="@color/blue_50"
                app:rippleColor="@color/blue_100"
                android:contentDescription="返回"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="22dp"
                app:icon="@drawable/ic_back"
                tools:ignore="PrivateResource" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_camera"
                style="@style/Widget.Material3.Button.Icon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                app:cornerRadius="14dp"
                app:iconTint="@color/blue_700"
                app:backgroundTint="@color/blue_50"
                app:rippleColor="@color/blue_100"
                android:contentDescription="拍照"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="22dp"
                app:icon="@drawable/icon_camera_switch"
                tools:ignore="PrivateResource" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_voice"
                style="@style/Widget.Material3.Button.Icon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                app:cornerRadius="14dp"
                app:iconTint="@color/blue_700"
                app:backgroundTint="@color/blue_50"
                app:rippleColor="@color/blue_100"
                android:contentDescription="语音输入"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="22dp"
                app:icon="@drawable/ic_mic_24"
                tools:ignore="PrivateResource" />





            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_ai_assist"
                style="@style/Widget.Material3.Button.Icon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                app:cornerRadius="14dp"
                app:iconTint="@color/blue_700"
                app:backgroundTint="@color/blue_50"
                app:rippleColor="@color/blue_100"
                android:contentDescription="AI 协助"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="22dp"
                app:icon="@drawable/ai"
                tools:ignore="PrivateResource" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>


    <LinearLayout
        android:id="@+id/message_bar_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@android:color/white"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp">


    </LinearLayout>


</LinearLayout>