<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white"
    android:padding="16dp">

    保留但隐藏测试标题，不影响你已有的顶栏
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="AI页面测试"
        android:textSize="24sp"
        android:textColor="#111111"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="16dp"
        android:visibility="gone" />

    气泡卡片：白底 + 圆角 + 阴影（悬浮感）
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_greeting"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardUseCompatPadding="true"
        app:cardCornerRadius="18dp"
        app:cardElevation="10dp"
        app:strokeWidth="0dp"
        app:cardBackgroundColor="@android:color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            文案
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_greeting_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="您好，我是你的智能AI助理。"
                    android:textColor="#111111"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:letterSpacing="0.01"
                    android:lineHeight="22sp" />

                <TextView
                    android:id="@+id/tv_greeting_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="#667185"
                    android:textSize="14sp"
                    android:lineSpacingExtra="2sp"
                    android:letterSpacing="0.005"
                    android:text="很高兴能和你互动。我可以为你解答、提炼内容…我会尽力为你提供优质的内容和方案。" />
            </LinearLayout>

            吉祥物图标（扁平化，蓝色主色）
            <ImageView
                android:id="@+id/img_robot"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginStart="12dp"
                android:padding="12dp"
                android:contentDescription="吉祥物"
                android:background="@android:color/transparent"
                app:tint="#1677FF"
                android:scaleType="centerInside"
                tools:src="@drawable/ic_settings_24" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    建议卡片：白底 + 圆角 + 阴影（去掉分隔线，气泡样式）
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_suggestions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardUseCompatPadding="true"
        app:cardCornerRadius="18dp"
        app:cardElevation="10dp"
        app:strokeWidth="0dp"
        app:cardBackgroundColor="@android:color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/tv_suggest_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="您可以尝试这样问我："
                android:textColor="#111111"
                android:textStyle="bold"
                android:textSize="16sp"
                android:letterSpacing="0.01"
                android:layout_marginBottom="6dp" />

            内部列表白底，去分割线改为块间距
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@android:color/white"
                android:paddingVertical="2dp"
                android:divider="@null"
                android:elevation="0dp">

                Item 1
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:background="@android:color/transparent"
                    android:layout_marginTop="2dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="#1F2937"
                        android:textSize="15sp"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:letterSpacing="0.005"
                        android:text="为我制定上班的最佳路线" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="更多"
                        app:tint="#C2CAD6"
                        tools:src="@drawable/ic_chevron_right_24" />
                </LinearLayout>

                分割线保留但隐藏（不删除组件）
                <com.google.android.material.divider.MaterialDivider
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:visibility="gone" />

                Item 2
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:background="@android:color/transparent"
                    android:layout_marginTop="2dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="#1F2937"
                        android:textSize="15sp"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:letterSpacing="0.005"
                        android:text="提供一份电商平台的用户画像" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="更多"
                        app:tint="#C2CAD6"
                        tools:src="@drawable/ic_chevron_right_24" />
                </LinearLayout>

                <com.google.android.material.divider.MaterialDivider
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:visibility="gone" />

                Item 3
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:background="@android:color/transparent"
                    android:layout_marginTop="2dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="#1F2937"
                        android:textSize="15sp"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:letterSpacing="0.005"
                        android:text="为市场经理撰写一份工作日报" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="更多"
                        app:tint="#C2CAD6"
                        tools:src="@drawable/ic_chevron_right_24" />
                </LinearLayout>

                <com.google.android.material.divider.MaterialDivider
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:visibility="gone" />

                Item 4
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:background="@android:color/transparent"
                    android:layout_marginTop="2dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="#1F2937"
                        android:textSize="15sp"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:letterSpacing="0.005"
                        android:text="以暑期亲子游为主题做一份旅游攻略" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="更多"
                        app:tint="#C2CAD6"
                        tools:src="@drawable/ic_chevron_right_24" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    底部输入区（保留现状）
    <LinearLayout
        android:id="@+id/message_bar_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@android:color/white"
        android:layout_marginTop="16dp">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:boxBackgroundMode="filled"
            app:boxBackgroundColor="#FFFFFFFF"
            app:boxStrokeColor="#1677FF"
            app:boxStrokeWidth="2dp"
            app:boxCornerRadiusTopStart="28dp"
            app:boxCornerRadiusTopEnd="28dp"
            app:boxCornerRadiusBottomStart="28dp"
            app:boxCornerRadiusBottomEnd="28dp"
            app:startIconDrawable="@drawable/ic_mic_24"
            app:startIconTint="#1677FF"
            app:endIconMode="none">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_message"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@android:color/transparent"
                android:hint="提供一份电商平台的用户画像"
                android:paddingEnd="8dp"
                android:textColor="#1F2937"
                android:textColorHint="#9AA4B2"
                android:letterSpacing="0.005"
                android:imeOptions="actionSend"
                android:inputType="textCapSentences|textMultiLine"
                android:maxLines="3"
                android:minLines="1" />
        </com.google.android.material.textfield.TextInputLayout>


    </LinearLayout>

</LinearLayout>