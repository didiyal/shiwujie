<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 背景图片 -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/background"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 标题栏 -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="家庭"
        android:textColor="@android:color/white"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 滚动视图 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 空状态提示 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardEmptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:visibility="gone"
                app:cardCornerRadius="12dp"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="32dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="24dp"
                        android:text="您还未加入任何家庭"
                        android:textColor="@android:color/black"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <!-- 加入家庭按钮 -->
                    <Button
                        android:id="@+id/btnJoinFamily"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:background="@drawable/bg_button_primary"
                        android:padding="12dp"
                        android:text="加入家庭"
                        android:textColor="@android:color/white"
                        android:textSize="16sp" />

                    <!-- 创建家庭按钮 -->
                    <Button
                        android:id="@+id/btnCreateFamily"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_button_primary"
                        android:padding="12dp"
                        android:text="创建家庭"
                        android:textColor="@android:color/white"
                        android:textSize="16sp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- 家庭信息卡片 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardFamilyInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- 家庭基本信息区域 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#F5F5F5"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- 家庭ID -->
                        <TextView
                            android:id="@+id/tvFamilyId"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:text="家庭ID: "
                            android:textColor="#757575"
                            android:textSize="14sp" />

                        <!-- 家庭名称和修改按钮的容器 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <!-- 家庭名称 -->
                            <TextView
                                android:id="@+id/tvFamilyName"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="家庭名称"
                                android:textColor="#2196F3"
                                android:textSize="24sp"
                                android:textStyle="bold" />

                            <!-- 修改信息按钮 -->
                            <Button
                                android:id="@+id/btnEditFamily"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/bg_button_primary"
                                android:padding="8dp"
                                android:text="修改信息"
                                android:textColor="@android:color/white" />
                        </LinearLayout>

                        <!-- 家庭描述 -->
                        <TextView
                            android:id="@+id/tvFamilyDescription"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="家庭描述"
                            android:textColor="#757575"
                            android:textSize="16sp" />

                        <!-- 创建者信息 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:background="@drawable/bg_creator_info"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="创建者"
                                android:textColor="#2196F3"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvCreator"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:textColor="#757575"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- 成员列表区域 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:orientation="vertical">

                        <!-- 盲人成员标题 -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="盲人成员"
                            android:textColor="#2196F3"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <!-- 盲人成员列表 -->
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvBlindMembers"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/bg_member_list"
                            android:nestedScrollingEnabled="false" />

                        <!-- 志愿者成员标题 -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="24dp"
                            android:text="志愿者成员"
                            android:textColor="#2196F3"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <!-- 志愿者成员列表 -->
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvVolunteerMembers"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/bg_member_list"
                            android:nestedScrollingEnabled="false" />

                    </LinearLayout>
                    <!-- 删除家庭按钮 -->
                    <Button
                        android:id="@+id/btnDeleteFamily"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="解散家庭"
                        android:textColor="@android:color/white"
                        android:background="@drawable/bg_button_red"
                        android:layout_marginTop="16dp"
                        android:visibility="gone" />

                    <Button
                        android:id="@+id/btnRemoveMembers"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="移除成员"
                        android:textColor="@android:color/white"
                        android:background="@drawable/bg_button_red"
                        android:layout_marginTop="8dp"
                        android:visibility="gone" />

                    <Button
                        android:id="@+id/btnLeaveFamily"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="退出家庭"
                        android:textColor="@android:color/white"
                        android:background="@drawable/bg_button_red"
                        android:layout_marginTop="8dp"
                        android:visibility="gone" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 家庭申请卡片 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardFamilyRequests"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                app:cardCornerRadius="12dp"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:text="加入申请"
                        android:textColor="#2196F3"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvFamilyRequests"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#F5F5F5"
                        android:nestedScrollingEnabled="false" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout> 