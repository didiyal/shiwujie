<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.swj.shiwujie.mapper.VideohelpMapper">

    <!-- v3.0.0 单体化阶段2.6：property 改 camelCase（实体 snake→camel）；column 保 snake_case（DB 列名不变，下划线映射自动匹配） -->
    <resultMap id="BaseResultMap" type="com.swj.shiwujie.model.domain.call.Videohelp">
            <id property="helpId" column="help_id" jdbcType="BIGINT"/>
            <result property="channelId" column="channel_id" jdbcType="BIGINT"/>
            <result property="blindId" column="blind_id" jdbcType="BIGINT"/>
            <result property="blindLatitude" column="blind_latitude" jdbcType="DECIMAL"/>
            <result property="blindLongitude" column="blind_longitude" jdbcType="DECIMAL"/>
            <result property="blindLocationAddress" column="blind_location_address" jdbcType="VARCHAR"/>
            <result property="volunteerId" column="volunteer_id" jdbcType="BIGINT"/>
            <result property="volunteerLatitude" column="volunteer_latitude" jdbcType="DECIMAL"/>
            <result property="volunteerLongitude" column="volunteer_longitude" jdbcType="DECIMAL"/>
