    <sql id="Base_Column_List">
        help_id,channel_id,blind_id,
        blind_latitude,blind_longitude,blind_location_address,
        volunteer_id,volunteer_latitude,volunteer_longitude,
        volunteer_location_address,help_status,start_time,
        response_time,end_time,duration,
        video_path,evaluation,create_time,
        update_time,is_delete
