<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>com.swj</groupId>
        <artifactId>shiwujieBackend</artifactId>
        <version>0.0.1-SNAPSHOT</version>
        <relativePath>../pom.xml</relativePath>
    </parent>
    <artifactId>shiwujieBootstrap</artifactId>
    <name>shiwujieBootstrap</name>
    <description>视无界单体启动模块（v3.0.0 单体化：唯一 @SpringBootApplication 入口，聚合 user/call/community/ai，repackage 产出可执行 jar）</description>

    <dependencies>
        <!-- 四业务模块（含 Dubbo 接缝点 v3.0.0 阶段2.2 转本地后同进程注入）；common-web/model 随传递依赖引入 -->
        <dependency>
            <groupId>com.swj</groupId>
            <artifactId>shiwujieUser</artifactId>
        </dependency>
        <dependency>
            <groupId>com.swj</groupId>
            <artifactId>shiwujieCall</artifactId>
        </dependency>
        <dependency>
            <groupId>com.swj</groupId>
            <artifactId>shiwujieCommunity</artifactId>
        </dependency>
        <dependency>
            <groupId>com.swj</groupId>
            <artifactId>shiwujieAi</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <!-- 唯一 repackage：单体可执行 jar（四业务模块在 2.1 已去 repackage，降为库） -->
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
                <configuration>
                    <excludes>
                        <exclude>
                            <groupId>org.projectlombok</groupId>
                            <artifactId>lombok</artifactId>
                        </exclude>
                    </excludes>
                </configuration>
            </plugin>
        </plugins>
    </build>

</project>
