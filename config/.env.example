# 视无界 Docker 运行时 env 模板（chunk-2d）。
#
# 用法：首次 ./scripts/start.sh 会自动 touch config/.env（空文件）→ 容器用 yml/config.py 的
# committed 默认值起。prod 要覆盖某项时，取消对应行注释并填真值（本 .env 被 .gitignore，不入库）。
#
# ⚠️ Docker 专用网络变量（MYSQL_HOST/REDIS_HOST/PYTHON_BASE_URL/SHIWUJIE_JAVA_MCP_URL/SHIWUJIE_AI_HOST）
#    已在 docker-compose.yml 的 environment 块硬设，**不**在此重复——本文件只放可选的凭据/模型覆盖。
#
# ⚠️ 凭据默认值见 application.yml / shiwujie-ai/src/shiwujie_ai/config.py（committed 内联，项目约定）。
#    下面各行默认注释=不覆盖（走 committed 默认）；prod 切真实环境时取消注释填真值。

# ── 凭据 / 模型覆盖（取消注释填真值才生效；留注释=走 committed 默认）──

# MySQL 密码（默认见 application.yml: MYSQL_PASSWORD）
#MYSQL_PASSWORD=

# Redis 密码（默认见 application.yml: REDIS_PASSWORD）
#REDIS_PASSWORD=

# Java 侧 DashScope key（兼容模式端点；默认见 application.yml: DASHSCOPE_API_KEY）
#DASHSCOPE_API_KEY=

# Python 侧主模型 key（百炼 provisioned MaaS；默认见 shiwujie_ai/config.py: SHIWUJIE_AI_API_KEY）
#SHIWUJIE_AI_API_KEY=
# 主对话/FC 模型（默认 qwen3.7-plus）/ VLM（默认 qwen3-vl-flash）/ base-url
#SHIWUJIE_AI_MODEL=
#SHIWUJIE_AI_VLM_MODEL=
#SHIWUJIE_AI_BASE_URL=

# 高德 / searchapi key（chunk-2c 真连外部 API 时填；空→走 mock，零网络零 key）
#SHIWUJIE_GAODE_KEY=
#SHIWUJIE_SEARCHAPI_KEY=
# Java web searchapi key（默认见 application.yml: SEARCH_API_KEY）
#SEARCH_API_KEY=

# Java↔Python 内部互信密钥（容器内网；默认 dev-internal-secret，prod 应改强值）
#AI_INTERNAL_SECRET=

# APK 下载路径（宿主宝塔静态文件；默认 /www/wwwroot/shiwujie/...）
#APK_PATH=
