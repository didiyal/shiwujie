#!/bin/sh
# pre-push hook: 推 origin 且本次含 master 时，自动镜像 master 到 github / practical-training。
#   - origin (Gitee 主): 所有分支 + PR (用户主动 push)
#   - github / practical-training: 只镜像 master (这两个不做 PR)
# 镜像失败不阻断 origin 主推; 防递归: 本 hook 只在 remote == origin 时动作,
# 镜像产生的子 push (remote=github/practical-training) 会被首行的 remote 判断直接放行。

remote_name="$1"
[ "$remote_name" = "origin" ] || exit 0

# 扫描本次推送的 ref 列表 (pre-push 的 stdin), 判断是否包含 master
has_master=0
while read -r _local_ref _local_sha remote_ref _remote_sha; do
    [ "$remote_ref" = "refs/heads/master" ] && has_master=1
done

[ "$has_master" = "1" ] || exit 0

echo "[pre-push] 镜像 master -> github / practical-training ..."
git push github master || echo "[pre-push] 警告: github 镜像失败 (已忽略, 不阻断 origin)"
git push practical-training master || echo "[pre-push] 警告: practical-training 镜像失败 (已忽略, 不阻断 origin)"
exit 0
